# Firebase Web SDK (frontend) — copy this file to .env and fill in your values
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=bugspacepro-27bb3.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bugspacepro-27bb3
VITE_FIREBASE_STORAGE_BUCKET=bugspacepro-27bb3.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=

# Backend API base URL
VITE_API_URL=http://localhost:4000

# Firebase Admin SDK (backend) — place in server/.env
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

